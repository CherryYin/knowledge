# =============================================
# Knowledgebase - 环境变量配置模板
# =============================================
# 复制此文件为 .env 并根据实际情况修改
# cp .env.example .env

# =============================================
# 数据库配置 (必需)
# =============================================

# PostgreSQL 连接字符串 (pgvector)
# 格式：postgresql://用户名：密码@主机：端口/数据库名
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge

# 是否允许在没有数据库的情况下启动服务 (开发调试用)
# 0 = false, 1 = true
ALLOW_START_WITHOUT_DB=0

# 是否跳过数据库迁移
# 0 = false, 1 = true
DB_SKIP_MIGRATION=0

# =============================================
# Embedding 服务配置 (必需)
# =============================================

# vLLM Embedding 服务地址
EMBEDDING_BASE_URL=http://localhost:8100

# Embedding 模型名称
EMBEDDING_MODEL=Qwen/Qwen2.5-VL-Embedding

# 是否使用本地 Transformers 模型 (替代 vLLM)
# 需要先安装：poetry install --extras local-embed
# false = 使用 vLLM, true = 使用本地模型
USE_LOCAL_EMBEDDING=false

# =============================================
# FAQ 存储配置 (FAQ 摄入必需)
# =============================================

# FAQ SQLite 数据库路径
FAQ_DB_PATH=./data/faq.db

# =============================================
# TLS / SSL 证书配置 (企业网络可选)
# =============================================

# 自定义 CA 证书路径 (如公司内网需要)
# SSL_CA_BUNDLE=/path/to/your-ca.pem

# 是否验证 SSL 证书
# 生产环境建议保持 true
SSL_VERIFY=true

# =============================================
# CORS 跨域配置 (可选)
# =============================================

# 允许的源，逗号分隔
# 留空表示仅允许同源
# ALLOW_ORIGINS=https://example.com,https://admin.example.com
ALLOW_ORIGINS=

# 是否允许携带凭证 (cookies/authorization headers)
ALLOW_CREDENTIALS=false

# =============================================
# HTTP 超时配置 (可选)
# =============================================

# HTTP 请求超时时间 (秒)
HTTP_TIMEOUT_SECONDS=8

# =============================================
# 外部文档分块同步 (可选)
# =============================================

# 外部系统的基础 URL
# DOCUMENT_SEGMENTS_BASE_URL=http://127.0.0.1:8001

# 外部系统的路径
# DOCUMENT_SEGMENTS_PATH=/api/v1/document_segments

# 外部系统的 Bearer Token (不含 "Bearer " 前缀)
# DOCUMENT_SEGMENTS_TOKEN=your-secret-token

# 外部系统请求超时时间 (秒)
# DOCUMENT_SEGMENTS_TIMEOUT_SECONDS=8

# =============================================
# 服务运行配置 (可选)
# =============================================

# 监听地址
HOST=0.0.0.0

# 监听端口
PORT=8000
